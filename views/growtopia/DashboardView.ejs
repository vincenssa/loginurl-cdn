<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SVPS Login Menu</title>
    <link rel="stylesheet" href="/base.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
</head>
<body class="bg-transparent">
    <div class="w-screen h-screen flex justify-center items-center">
        <div class="border-2 border-[#b8860b] p-5 text-[#eeeeee] bg-gradient-to-br min-w-[50vw] from-[#1a1a1a] to-[#2a2a00] rounded-lg shadow-xl shadow-[#b8860b]">
            <h1 class="text-center text-2xl font-bold" style="color:#ffd700"><%= cnf.name %> Menu</h1>
            <p style="color:#c9a84c" class="opacity-70">You are now entering the login page of this server. Please enter your <span style="color:#ffd700" class="font-semibold">GrowID</span> and <span style="color:#ffd700" class="font-semibold">Password</span> if you already have an account, or log in as a guest.</p>
            <button type="button"
                class="btn btn-primary hidden"
                data-toggle="modal"
                id="modalButton"
                data-target="#modalShow"
                data-backdrop="static"
                data-keyboard="false"
                hidden
            ></button>
            <form 
            action="/player/growid/login/validate" accept-charset="UTF-8"
            role="form"
            required="required"
            autocomplete="off" method="post" class="mt-3">
                <div class="mb-1">
                    <input
                        name="_token"
                        type="hidden"
                        value=""
                    />
                    <label for="loginGrowId" class="block text-white text-md">GrowID:</label>
                    <div class="flex items-center border-2 border-[#b8860b] rounded bg-[#1a1a1a] px-3 py-1 gap-2">
                        <i class="fas fa-user mr-1 text-md" style="color:#ffd700"></i>
                        <input type="text" name="growId" id="loginGrowId" class="w-full bg-[#1a1a1a] text-white text-md placeholder-[#c9a84c] focus:outline-none" placeholder="Enter your growid" required>
                    </div>
                </div>
                <div class="mb-1">
                    <label for="loginPassword" class="block text-white text-md">Password:</label>
                    <div class="flex items-center border-2 border-[#b8860b] rounded bg-[#1a1a1a] px-3 py-1 gap-2">
                        <i class="fas fa-lock mr-1 text-md" style="color:#ffd700"></i>
                        <input type="password" name="password" id="loginPassword" class="w-full bg-[#1a1a1a] text-white text-md placeholder-[#c9a84c] focus:outline-none" placeholder="Enter your password" required>
                        <button type="button" id="toggleLogPassword" class="ml-2 focus:outline-none text-xs" style="color:#ffd700">
                            <i class="fas fa-eye-slash"></i>
                        </button>
                    </div>
                </div>
                <div class="flex justify-end items-center flex-col md:flex-row gap-2 mt-3">
                    <button id="loginButton" type="submit" class="px-2 py-1 rounded text-black text-xl font-bold w-full transition duration-300 ease-in-out transform" style="background-color:#ffd700; hover:background-color:#c9a84c">Login</button>
                    <button id="regisButton" type="button" class="px-2 py-1 rounded text-black text-xl font-bold w-full transition duration-300 ease-in-out transform" style="background-color:#ffd700">Create New GrowID</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        const growId = document.getElementById("loginGrowId");
        const password = document.getElementById("loginPassword");
        const form = document.querySelector("form");
        
        document.getElementById('toggleLogPassword').addEventListener('click', function () {
            const LpasswordField = document.getElementById('loginPassword')
            const LpasswordFieldType = LpasswordField.getAttribute('type');
            if (LpasswordFieldType === 'password') {
                LpasswordField.setAttribute('type', 'text');
                this.innerHTML = '<i class="fas fa-eye"></i>';
            } else {
                LpasswordField.setAttribute('type', 'password');
                this.innerHTML = '<i class="fas fa-eye-slash"></i>';
            }
        });
    
        document.getElementById("regisButton").addEventListener("click", function () {
         const token = btoa(`_token=NONE&growId=&password=`);

            window.location.href = "/player/growid/login/validate?data=" + encodeURIComponent(token);
    });

        form.addEventListener("submit", async (e) => {
            e.preventDefault();

            const token = btoa(`_token=NONE&growId=${growId.value}&password=${password.value}`);

            window.location.href = "/player/growid/login/validate?data=" + encodeURIComponent(token);
        });
    </script>
</body>
</html>
